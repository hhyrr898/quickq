<section class="section" id="scenes">
  <div class="container">
    <div class="section-head">
    </div>
    <div class="grid">
      {% set cards = [
        ["安装前检查", "确认系统版本、存储空间与账号状态。"],
        ["桌面端连接", "梳理 Windows 与 macOS 的常见设置。"],
        ["移动端准备", "覆盖 Android 与 iOS 的权限确认。"],
        ["账号安全", "整理登录保护、设备管理与资料同步。"],
        ["连接维护", "遇到延迟或断开时按步骤检查。"],
        ["远程办公", "适合跨地点访问办公系统与资料。"],
        ["学习资料", "适合课程访问、资料查询与协作。"],
        ["多设备切换", "在手机、平板、电脑间保持一致体验。"]
      ] %}
      {% for card in cards %}
        <article class="card">
          <h3>{{ card[0] }}</h3>
          <p>{{ card[1] }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section" id="latest">
  <div class="container">
    <div class="section-head">
      <div>
        <h2>QuickQ 文章更新</h2>
      </div>
    </div>
    <div class="article-list">
      {% for post in collections.posts | sortByDateDesc %}
        {% if loop.index <= 12 %}
          <article class="article-link">
            {% if post.data.heroImage %}
              <a class="preview-link" href="{{ post.url }}">
                <img class="article-thumb" src="{{ post.data.heroImage }}" alt="{{ post.data.heroAlt or post.data.title }}" loading="lazy">
              </a>
            {% endif %}
            <time datetime="{{ post.date | readableDate }}">{{ post.date | readableDate }}</time>
            <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
            <p>{{ post.data.description }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
