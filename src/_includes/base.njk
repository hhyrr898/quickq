<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {% set docTitle = title or site.title %}
    {% set metaDescription = description or site.description %}
    {% set canonical = site.url + (canonicalUrl or page.url or "/") %}
    <title>{{ docTitle }}</title>
    <meta name="description" content="{{ metaDescription }}">
    {% if noindex %}
    <meta name="robots" content="noindex,follow">
    {% else %}
    <meta name="robots" content="index,follow,max-image-preview:large">
    {% endif %}
    <link rel="canonical" href="{{ canonical }}">
    <meta property="og:type" content="{% if layout == 'article.njk' %}article{% else %}website{% endif %}">
    <meta property="og:title" content="{{ docTitle }}">
    <meta property="og:description" content="{{ metaDescription }}">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:site_name" content="{{ site.name }}">
    <meta property="og:locale" content="zh_CN">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="icon" href="/favicon.ico" type="image/svg+xml">
    <link rel="stylesheet" href="/assets/styles.css">
    <script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": site.name,
  "url": site.url,
  "description": site.description
} | dump | safe }}
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="/" aria-label="QuickQ">
          <img src="/assets/logo.svg" alt="QuickQ 标识" width="46" height="46">
          <span>QuickQ</span>
        </a>
        <nav class="nav" aria-label="主导航">
          <a href="/">首页</a>
          <a href="/dows.html">下载中心</a>
          <a href="/blog/">博客</a>
          <a href="/about/">关于</a>
        </nav>
      </div>
    </header>
    <main>
      {{ content | safe }}
    </main>
    <footer class="site-footer">
      <div class="container footer-grid">
        <section>
          <h2>QuickQ下载与使用资料</h2>
          <p>整理安装、设备配置、连接维护与移动端使用内容，让不同设备的准备过程更清楚。</p>
        </section>
        <nav aria-label="页脚导航">
          <a href="/">quickq 资源中心</a>
          <a href="/dows.html">客户端下载</a>
          <a href="/blog/">使用文章</a>
          <a href="/about/">关于本站</a>
          <a href="/sitemap.xml">站点地图</a>
        </nav>
      </div>
    </footer>
    <script charset="UTF-8" id="LA_COLLECT" src="//sdk.51.la/js-sdk-pro.min.js" defer></script>
    <script>window.addEventListener("load",function(){if(window.LA){LA.init({id:"{{ site.laId }}",ck:"{{ site.laId }}"})}})</script>
  </body>
</html>
