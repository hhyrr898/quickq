---
layout: base.njk
---
<div class="container page-shell">
  <article class="article-page">
    <p class="eyebrow">{{ category or "使用资料" }}</p>
    <h1>{{ title }}</h1>
    <p class="article-meta">{{ page.date | readableDate }} · QuickQ 使用资料</p>
    {% if heroImage %}
      <img class="article-hero" src="{{ heroImage }}" alt="{{ heroAlt or title }}" loading="lazy">
    {% endif %}
    {{ content | safe }}
    {% if videoTitle %}
      <section class="video-panel" aria-labelledby="video-title">
        <h2 id="video-title">{{ videoTitle }}</h2>
        <p>{{ videoDescription }}</p>
        <div class="video-frame">
          <img src="{{ videoPoster }}" alt="{{ videoTitle }} 视频画面" loading="lazy">
          <span>视频安装教程</span>
        </div>
      </section>
    {% endif %}
  </article>
  <script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": page.date | readableDate,
  "dateModified": updated or (page.date | readableDate),
  "author": {
    "@type": "Organization",
    "name": site.author
  },
  "publisher": {
    "@type": "Organization",
    "name": site.name,
    "url": site.url
  },
  "mainEntityOfPage": site.url + page.url
} | dump | safe }}
  </script>
  <script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "首页",
      "item": site.url + "/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "博客",
      "item": site.url + "/blog/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": site.url + page.url
    }
  ]
} | dump | safe }}
  </script>
  <aside class="side-panel">
    <h2>相关入口</h2>
    <a href="/dows.html">客户端下载</a>
    <a href="/blog/">全部文章</a>
    <a href="/tags/">Tags 聚合</a>
    {% set cleanTags = tags | publicTags %}
    {% if cleanTags.length %}
      <h2>Tags</h2>
      <div class="tag-list">
        {% for tag in cleanTags %}
          <a href="/tags/{{ tag | tagSlug }}/">{{ tag }}</a>
        {% endfor %}
      </div>
    {% endif %}
  </aside>
</div>
